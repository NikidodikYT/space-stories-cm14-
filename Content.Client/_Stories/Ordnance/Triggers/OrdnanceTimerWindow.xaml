<DefaultWindow xmlns="https://spacestation14.io" Title="{Loc stories-ordnance-timer-title}" MinSize="360 130">
    <BoxContainer Orientation="Vertical" SeparationOverride="5" Margin="5" HorizontalExpand="True">
        <PanelContainer Name="StatusPanel" Access="Public" StyleClasses="AngleRect" ModulateSelfOverride="#b22222">
            <Label Name="StatusLabel" Access="Public" Text="Disabled" HorizontalAlignment="Center" Margin="5" />
        </PanelContainer>
        <BoxContainer Orientation="Horizontal" SeparationOverride="10" Margin="5 10 5 0" HorizontalExpand="True">
            <Label Text="{Loc stories-ordnance-timer-time}" MinWidth="90" />
            <Slider
                Name="TimeSlider"
                MinValue="3"
                MaxValue="120"
                HorizontalExpand="True"
                VerticalAlignment="Center"
                Access="Public"
            />
            <SpinBox Name="TimeSpinBox" Value="5" MinWidth="75" Access="Public" />
        </BoxContainer>
    </BoxContainer>
</DefaultWindow>
